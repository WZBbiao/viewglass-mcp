{
  "name": "viewglass-mcp",
  "version": "0.1.0",
  "description": "MCP Server for Viewglass iOS UI inspection — bundles the viewglass CLI binary",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "viewglass-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WZBbiao/viewglass-mcp.git"
  },
  "homepage": "https://github.com/WZBbiao/viewglass-mcp",
  "keywords": ["mcp", "ios", "ui-automation", "viewglass", "ai", "claude", "inspector"],
  "files": [
    "dist/",
    "bin/",
    ".viewglass-cli-version",
    ".viewglass-server-min-version"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx tsx src/__tests__/e2e.ts",
    "export:flow": "node scripts/export-flow-from-log.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
