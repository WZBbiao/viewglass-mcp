{
  "name": "viewglass-mcp",
  "version": "0.1.0",
  "description": "MCP Server for Viewglass iOS UI inspection — bundles the viewglass CLI binary",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "viewglass-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "bin/",
    ".viewglass-cli-version"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && npx tsx src/__tests__/e2e.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
